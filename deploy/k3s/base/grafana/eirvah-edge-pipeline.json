        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "title": "Stage Error + Timeout Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "eirvah-prometheus"
          },
          "expr": "sum by (stage) (rate(eirvah_pipeline_stage_error_total{path=\"telemetry\"}[1m]))",
          "legendFormat": "error {{stage}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
