      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "eirvah-prometheus"
          },
          "expr": "eirvah_ingress_connection_state{state=\"connected\"}",
          "legendFormat": "{{ingress}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "eirvah-prometheus"
      },
